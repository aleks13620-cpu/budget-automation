PORT=3001
DATABASE_PATH=../database/budget_automation.db
UPLOAD_PATH=../data/uploads

# GigaChat API (НЕ коммитить реальный ключ)
# Получить ключ: https://developers.sber.ru/portal/products/gigachat
GIGACHAT_AUTH_KEY=your_base64_auth_key_here
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODELS_FILES=GigaChat-2-Lite,GigaChat-2-Pro,GigaChat-2-Max

# OpenRouter API (для Gemini OCR fallback на сканированных PDF)
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Feature flags
USE_LEGACY_PARSER=false

# Security
API_SECRET=
ALLOWED_ORIGINS=http://localhost:5173
