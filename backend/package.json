{
  "name": "budget-automation-backend",
  "version": "1.0.0",
  "description": "Backend for budget automation system",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:init": "ts-node src/database/init.ts",
    "db:seed-construction-synonyms": "ts-node src/database/seedConstructionSynonyms.ts",
    "problem-registry:add": "node ../scripts/problem-registry.mjs add",
    "problem-registry:update": "node ../scripts/problem-registry.mjs update",
    "problem-registry:resolve": "node ../scripts/problem-registry.mjs resolve",
    "problem-registry:reopen": "node ../scripts/problem-registry.mjs reopen",
    "problem-registry:list": "node ../scripts/problem-registry.mjs list",
    "problem-registry:stats": "node ../scripts/problem-registry.mjs stats",
    "problem-registry:prioritize": "node ../scripts/problem-registry.mjs prioritize --sync-priority",
    "problem-registry:scan": "node ../scripts/problem-registry.mjs scan",
    "problem-registry:validate": "node ../scripts/problem-registry.mjs validate",
    "problem-registry:report": "node ../scripts/problem-registry.mjs report",
    "problem-registry:db:snapshot": "node ../scripts/problem-registry.mjs db:snapshot"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "string-similarity": "^4.0.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.2.1",
    "@types/string-similarity": "^4.0.2",
    "pdfkit": "^0.17.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
